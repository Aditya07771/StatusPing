# ===========================================
# StatusPing Environment Configuration
# ===========================================

# Database
# PostgreSQL connection string
DATABASE_URL="postgresql://statusping:password@localhost:5432/statusping"

# Redis
# Redis connection string
REDIS_URL="redis://localhost:6379"

# Authentication & Security
# JWT secret key (generate with: openssl rand -base64 32)
# MUST be at least 32 characters
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_EXPIRES_IN="7d"

# Email Configuration (SMTP)
# SMTP server hostname
SMTP_HOST="smtp.gmail.com"
# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587
# SMTP authentication username
SMTP_USER="your-email@gmail.com"
# SMTP authentication password or app-specific password
SMTP_PASS="your-smtp-password"
# Email address to send notifications from
SMTP_FROM="alerts@yourdomain.com"

# Webhook Security
# Encryption key for webhook secrets (generate with: openssl rand -base64 32)
# MUST be at least 32 characters
WEBHOOK_ENCRYPTION_KEY="your-webhook-encryption-key-minimum-32-chars"

# Application
# Environment: development, production, or test
NODE_ENV="development"
# API server port
PORT=3000
# Public URL of the application
APP_URL="http://localhost:3000"

# Worker Configuration
# Number of concurrent ping jobs to process
PING_WORKER_CONCURRENCY=10
# Cooldown period between duplicate notifications (in seconds)
NOTIFICATION_COOLDOWN_SECONDS=1800
# Number of days to retain raw ping logs before aggregation
PING_LOG_RETENTION_DAYS=30