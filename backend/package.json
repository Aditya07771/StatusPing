{
  "name": "statusping",
  "version": "1.0.0",
  "description": "Self-hosted uptime monitoring platform",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/api/server.ts",
    "dev:api": "tsx watch --env-file=.env src/api/server.ts",
    "dev:worker": "tsx watch --env-file=.env src/worker/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/api/server.js",
    "start:api": "node --env-file=.env dist/api/server.js",
    "start:worker": "node --env-file=.env dist/worker/index.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "uptime",
    "monitoring",
    "status-page",
    "health-check"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.13.2",
    "express": "^5.0.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.15",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "overrides": {
    "@types/express-serve-static-core": "5.0.6",
    "ioredis": "5.10.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^6.4.16",
    "@vitest/coverage-v8": "^2.1.2",
    "prisma": "^5.19.1",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}